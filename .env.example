# Required for LLM agents
# Preferred: LLM_API_KEY
# Backward compatible: OPENAI_API_KEY / DEEPSEEK_API_KEY
LLM_API_KEY=your-api-key-1
OPENAI_API_KEY=your-api-key-1
DEEPSEEK_API_KEY=your_deepseek_api_key

# LLM provider (OpenAI-compatible)
# Example for local "cli" provider:
LLM_API_BASE=http://localhost:8317/v1
OPENAI_API_BASE=http://localhost:8317/v1
LLM_WIRE_API=responses
LLM_MODEL=gpt-5.2
LLM_REASONING_EFFORT=xhigh
LLM_DISABLE_RESPONSE_STORAGE=true
LLM_TEMPERATURE=0.7
LLM_ENABLE_CACHE=true
LLM_CACHE_DIR=outputs/cache/llm
LLM_MAX_RETRIES=2
LLM_RETRY_BACKOFF_SECONDS=0.6
LLM_TIMEOUT_SECONDS=120
LLM_MAX_OUTPUT_TOKENS=900
LLM_PREFLIGHT=true
LLM_PREFLIGHT_TIMEOUT_SECONDS=2

# Web async jobs
WEB_JOB_TTL_SECONDS=3600
WEB_MAX_JOBS=64
WEB_MAX_CONCURRENT_JOBS=2

# Embeddings
EMBEDDING_MODEL=text-embedding-v3

# Knowledge base path
CHROMA_PERSIST_DIR=./chroma_db

# Optional vision generation (used when skip-vision is false)
DASHSCOPE_API_KEY=your_dashscope_api_key
IMAGE_GEN_MODEL=qwen-image
IMAGE_GEN_SIZE=1024*1024

# Output path
OUTPUT_DIR=outputs
