# Required for LLM agents
DEEPSEEK_API_KEY=your_deepseek_api_key

# Optional LLM overrides
OPENAI_API_BASE=https://www.sophnet.com/api/open-apis/v1
LLM_MODEL=deepseek-chat
EMBEDDING_MODEL=text-embedding-v3

# Knowledge base path
CHROMA_PERSIST_DIR=./chroma_db

# Optional vision generation (used when skip-vision is false)
DASHSCOPE_API_KEY=your_dashscope_api_key
IMAGE_GEN_MODEL=qwen-image
IMAGE_GEN_SIZE=1024*1024

# Output path
OUTPUT_DIR=outputs
